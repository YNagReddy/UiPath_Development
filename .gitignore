
################################################################################
# UiPath Studio — Comprehensive .gitignore
################################################################################

# ── UiPath Internal / Cache Directories ──
.local/
.objects/
.settings/
.project/
.templates/
.tmh/
.entities/
.screenshots/
.storage/

# ── Excel Temp Lock Files ──
~$*.xlsx
~$*.xls

# ── OS / Editor ──
Thumbs.db
Desktop.ini
.DS_Store
*.suo
*.user
*.userosscache
*.sln.docstates

# ── Visual Studio ──
.vs/
bin/
obj/

# ── NuGet ──
packages/

################################################################################
# End of UiPath .gitignore
################################################################################
